  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.0",
    "@ai-sdk/azure": "^3.0.0",
    "@ai-sdk/google": "^3.0.0",
    "@ai-sdk/openai": "^3.0.0",
    "@ai-sdk/openai-compatible": "^2.0.0",
    "@modelcontextprotocol/sdk": "^1.27.0",
    "ai": "^4.0.0",
    "better-sqlite3": "^11.0.0",
    "chokidar": "^4.0.0",
    "drizzle-orm": "^0.40.0",
    "effect": "^3.0.0",
    "fuzzysort": "^3.1.0",
    "gray-matter": "^4.0.0",
    "remeda": "^2.0.0",
    "semver": "^7.6.0",
    "ulid": "^2.3.0",
    "yargs": "^18.0.0",
