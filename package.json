{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "opencode2",
  "version": "2.0.0-alpha.1",
  "type": "module",
  "license": "MIT",
  "private": false,
  "description": "OpenCode2 - Open Source AI Coding Agent with Jeeves Orchestration",
  "repository": {
    "type": "git",
    "url": "https://github.com/noktirnal42/opencode2"
  },
  "bin": {
    "opencode2": "./dist/cli/index.js"
  },
  "scripts": {
    "dev": "tsx src/cli/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
